# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./lexdrift.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/lexdrift

# SEC EDGAR
SEC_USER_AGENT=LexDrift your-email@example.com
SEC_RATE_LIMIT=10

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# NLP
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FINBERT_MODEL=ProsusAI/finbert
USE_FINBERT_SENTIMENT=true
SPACY_MODEL=en_core_web_sm

# LLM (Groq — free tier, Llama 3.3 70B)
# Get a free API key at https://console.groq.com
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_ENABLED=true

# Alerts
DRIFT_THRESHOLD=0.15
SENTIMENT_STDDEV_MULTIPLIER=2.0
